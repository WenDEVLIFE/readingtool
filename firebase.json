{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "netlify/**",
      "netlify.toml",
      ".agents/**",
      "database/**"
    ],
    "redirects": [
      {
        "source": "/.netlify/functions/stt-transcribe",
        "destination": "https://word-harbor.netlify.app/.netlify/functions/stt-transcribe",
        "type": 307
      },
      {
        "source": "/.netlify/functions/azure-pronunciation-assessment",
        "destination": "https://word-harbor.netlify.app/.netlify/functions/azure-pronunciation-assessment",
        "type": 307
      },
      {
        "source": "/.netlify/functions/student-attempt-start",
        "destination": "https://word-harbor.netlify.app/.netlify/functions/student-attempt-start",
        "type": 307
      },
      {
        "source": "/.netlify/functions/student-attempt-complete",
        "destination": "https://word-harbor.netlify.app/.netlify/functions/student-attempt-complete",
        "type": 307
      },
      {
        "source": "/.netlify/functions/teacher-login",
        "destination": "https://word-harbor.netlify.app/.netlify/functions/teacher-login",
        "type": 307
      },
      {
        "source": "/.netlify/functions/teacher-register",
        "destination": "https://word-harbor.netlify.app/.netlify/functions/teacher-register",
        "type": 307
      },
      {
        "source": "/.netlify/functions/teacher-results-list",
        "destination": "https://word-harbor.netlify.app/.netlify/functions/teacher-results-list",
        "type": 307
      }
    ]
  }
}
